# Copy to .env and fill in. NEVER commit the real .env.

# ===== GLM via Fireworks (OpenAI-compatible) =====
GLM_BASE_URL=https://api.fireworks.ai/inference/v1
GLM_API_KEY=fw_your_fireworks_key_here
# main/strong tier (replaces plugin "opus" agents)
GLM_MODEL_MAIN=accounts/fireworks/models/glm-5p2
# triage/cheap tier (replaces plugin "sonnet" agents)
# Can point at a cheaper model (e.g. glm-4p7-flash) to split tiers and save cost.
GLM_MODEL_TRIAGE=accounts/fireworks/models/glm-5p2

# ===== Voiceflow MCP (the agents' toolset) =====
VF_MCP_URL=https://mcp.voiceflow.com/mcp
VF_MCP_TOKEN=your_voiceflow_mcp_oauth_bearer_token
