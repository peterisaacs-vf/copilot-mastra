{
  "name": "copilot-mastra",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "description": "Voiceflow copilot rebuilt on Mastra + GLM (Fireworks). Faithful port of the voiceflow/mcp-plugin.",
  "scripts": {
    "dev": "mastra dev",
    "generate:assets": "tsx src/scripts/embedAssets.ts",
    "prebuild": "npm run generate:assets",
    "build": "mastra build",
    "postbuild": "tsx src/scripts/fixStudioRoutes.ts",
    "build:studio": "npm run generate:assets && mastra build --studio",
    "typecheck": "tsc --noEmit",
    "smoke:debug": "tsx src/scripts/debugSmoke.ts",
    "smoke:analyze": "tsx src/scripts/analyzeSmoke.ts",
    "smoke:optimize": "tsx src/scripts/optimizeSmoke.ts",
    "test:parse": "tsx src/scripts/testParse.ts",
    "audit:wiring": "tsx src/scripts/wiringAudit.ts"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "1.0.41",
    "@mastra/core": "1.45.0",
    "@mastra/editor": "^0.13.0",
    "@mastra/libsql": "^1.14.0",
    "@mastra/mcp": "1.11.0",
    "@mastra/memory": "^1.21.0",
    "@mastra/pg": "^1.14.0",
    "dotenv": "^16.4.7",
    "yaml": "^2.9.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@mastra/deployer-vercel": "^1.2.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "mastra": "1.15.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
