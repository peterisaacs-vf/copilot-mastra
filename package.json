{
  "name": "copilot-mastra",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "description": "Voiceflow copilot rebuilt on Mastra + GLM (Fireworks). Faithful port of the voiceflow/mcp-plugin.",
  "scripts": {
    "dev": "mastra dev",
    "build": "mastra build",
    "typecheck": "tsc --noEmit",
